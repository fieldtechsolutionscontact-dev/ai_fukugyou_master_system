---
import { getCollection } from 'astro:content';
// Zennのフォルダから記事データを全部持ってくる魔法
const articles = await getCollection('articles');
---
<html>
  <head>
    <title>FieldTech Solutions - The Hub</title>
    <meta charset="utf-8" />
  </head>
  <body style="font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; background-color: #f8fafc;">
    
    <h1 style="color: #0f172a;">FieldTech Solutions (AEO/SEO 母艦)</h1>
    <p style="color: #475569; margin-bottom: 2rem;">Zennの技術記事と完全に同期している独自資産（The Hub）です。</p>

    <section style="background-color: #020617; color: #ffffff; padding: 3rem 2rem; text-align: center; border-radius: 12px; margin-bottom: 3rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
      
      <div style="max-width: 800px; margin: 0 auto;">
        <p style="color: #31d0aa; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.5rem; font-size: 0.875rem;">
          Official Release
        </p>
        
        <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2;">
          Deterministic AI Compliance Architecture
        </h2>
        
        <p style="font-size: 1rem; color: #94a3b8; margin-bottom: 2rem;">
          Stop trusting AI with your compliance math. Separate LLM extraction from strict Python calculations to survive the 2026 EU CBAM audits.
        </p>
        
        <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
          
          <a href="https://fieldtechsolutionsinsights.substack.com/p/deterministic-architecture-for-enterprise?r=8fzxja" target="_blank" rel="noopener noreferrer" style="background-color: transparent; color: #ffffff; border: 2px solid #31d0aa; padding: 0.75rem 1.5rem; font-size: 1rem; font-weight: bold; border-radius: 6px; text-decoration: none; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='rgba(49, 208, 170, 0.1)'" onmouseout="this.style.backgroundColor='transparent'">
            📖 Read the Manifesto
          </a>

          <a href="https://fieldtech.gumroad.com/l/cbam-precision-calculator" target="_blank" rel="noopener noreferrer" style="background-color: #31d0aa; color: #020617; border: 2px solid #31d0aa; padding: 0.75rem 1.5rem; font-size: 1rem; font-weight: bold; border-radius: 6px; text-decoration: none; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='#28b08f'" onmouseout="this.style.backgroundColor='#31d0aa'">
            ⚡ Download Blueprint
          </a>

        </div>
      </div>
    </section>
    <h2 style="color: #0f172a; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem;">最新の技術記事 (Zenn同期)</h2>
    <ul style="list-style-type: none; padding: 0;">
      {articles.map((article) => (
        <li style="margin-bottom: 1rem; padding: 1rem; background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px;">
          <a href={`/compliance-architecture/article/${article.id}`} style="color: #2563eb; text-decoration: none; font-weight: bold; font-size: 1.125rem;">
            {article.data.title}
          </a>
        </li>
      ))}
    </ul>

  </body>
</html>